#!/usr/bin/env python3
# /// script
# requires-python = ">=3.10"
# ///
"""Quick UDP smoke test for MAVLink traffic."""

from __future__ import annotations

import argparse
import socket
import sys
import time


def packet_summary(data: bytes) -> str:
    if len(data) >= 10 and data[0] == 0xFD:
        msgid = data[7] | (data[8] << 8) | (data[9] << 16)
        return f"MAVLink2 sysid={data[5]} compid={data[6]} msgid={msgid}"
    if len(data) >= 8 and data[0] == 0xFE:
        return f"MAVLink1 sysid={data[3]} compid={data[4]} msgid={data[5]}"
    return "unknown packet format"


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Listen briefly for inbound MAVLink UDP traffic.")
    parser.add_argument("--bind", default="0.0.0.0", help="local bind address; default: 0.0.0.0")
    parser.add_argument("--port", type=int, default=14550, help="UDP port; default: 14550")
    parser.add_argument("--timeout", type=float, default=8.0, help="seconds to wait; default: 8")
    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(sys.argv[1:] if argv is None else argv)
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    sock.settimeout(0.25)
    try:
        sock.bind((args.bind, args.port))
    except OSError as exc:
        print(f"ERROR: could not bind UDP {args.bind}:{args.port}: {exc}", file=sys.stderr)
        print("Close QGC or choose another --port if the port is already in use.", file=sys.stderr)
        return 1

    print(f"checking UDP {args.bind}:{args.port} for {args.timeout:g}s")
    deadline = time.monotonic() + args.timeout
    while time.monotonic() < deadline:
        try:
            data, (host, port) = sock.recvfrom(65535)
        except socket.timeout:
            continue
        print(f"received {len(data)} bytes from {host}:{port}: {packet_summary(data)}")
        return 0

    print("ERROR: no UDP MAVLink traffic observed before timeout", file=sys.stderr)
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
