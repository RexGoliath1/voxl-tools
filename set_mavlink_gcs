#!/usr/bin/env python3
# /// script
# requires-python = ">=3.10"
# ///
"""Set voxl-mavlink-server's static GCS IP over adb or SSH."""

from __future__ import annotations

import argparse
import datetime as dt
import ipaddress
import os
import platform
import re
import shutil
import socket
import subprocess
import sys
import tempfile
from dataclasses import dataclass
from pathlib import Path


DEFAULT_REMOTE_USER = "root"
DEFAULT_REMOTE_PASSWORD = "oelinux123"
DEFAULT_CONFIG_PATH = "/etc/modalai/voxl-mavlink-server.conf"
DEFAULT_FIELD = "secondary_static_gcs_ip"
DEFAULT_SERVICE = "voxl-mavlink-server"


@dataclass(frozen=True)
class Args:
    transport: str
    ip: str | None
    interface: str | None
    drone_ip: str | None
    user: str
    password: str
    ssh_port: int
    serial: str | None
    field: str
    config: str
    service: str
    adb: str
    dry_run: bool
    no_restart: bool
    check_udp: bool
    udp_port: int
    udp_timeout: float


def run(
    cmd: list[str],
    *,
    check: bool = True,
    env: dict[str, str] | None = None,
) -> subprocess.CompletedProcess[str]:
    try:
        result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, env=env)
    except FileNotFoundError as exc:
        raise RuntimeError(f"{cmd[0]!r} was not found") from exc
    if check and result.returncode != 0:
        detail = result.stderr.strip() or result.stdout.strip() or f"exit code {result.returncode}"
        raise RuntimeError(f"{' '.join(cmd)} failed: {detail}")
    return result


def shell_quote(value: str) -> str:
    return "'" + value.replace("'", "'\"'\"'") + "'"


def validate_ipv4(value: str) -> str:
    try:
        ip = ipaddress.ip_address(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError(str(exc)) from exc
    if ip.version != 4:
        raise argparse.ArgumentTypeError("expected an IPv4 address")
    return value


def detect_ip_for_interface(interface: str) -> str:
    if platform.system() == "Darwin":
        result = run(["ipconfig", "getifaddr", interface], check=False)
        ip = result.stdout.strip()
        if result.returncode == 0 and ip:
            return validate_ipv4(ip)
        raise RuntimeError(f"could not find an IPv4 address for interface {interface!r}")

    result = run(["ip", "-4", "addr", "show", "dev", interface], check=False)
    if result.returncode == 0 and (match := re.search(r"\binet\s+(\d+\.\d+\.\d+\.\d+)/", result.stdout)):
        return validate_ipv4(match.group(1))

    result = run(["ifconfig", interface], check=False)
    if result.returncode == 0 and (match := re.search(r"\binet (?:addr:)?(\d+\.\d+\.\d+\.\d+)", result.stdout)):
        return validate_ipv4(match.group(1))

    raise RuntimeError(f"could not find an IPv4 address for interface {interface!r}")


def detect_route_ip(target: str) -> str:
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        sock.connect((target, 80))
        return validate_ipv4(sock.getsockname()[0])
    except OSError as exc:
        raise RuntimeError("could not auto-detect host IPv4 address; rerun with --ip or --interface") from exc
    finally:
        sock.close()


def edit_config_text(text: str, field: str, ip: str) -> tuple[str, str]:
    pattern = re.compile(r'("' + re.escape(field) + r'"\s*:\s*")([^"]*)(")')
    match = pattern.search(text)
    if not match:
        known = sorted(set(re.findall(r'"([^"]*static_gcs_ip)"\s*:', text)))
        known_msg = ", ".join(known) if known else "none found"
        raise RuntimeError(f"field {field!r} was not found. Known static GCS IP fields: {known_msg}")
    old_ip = match.group(2)
    new_text = pattern.sub(r"\g<1>" + ip + r"\3", text, count=1)
    return new_text, old_ip


def run_udp_checker(port: int, timeout: float) -> None:
    checker = Path(__file__).with_name("check_mavlink_udp")
    if not checker.exists():
        raise RuntimeError(f"UDP checker not found: {checker}")
    result = run([sys.executable, str(checker), "--port", str(port), "--timeout", str(timeout)], check=False)
    if result.stdout:
        print(result.stdout.rstrip())
    if result.stderr:
        print(result.stderr.rstrip(), file=sys.stderr)
    if result.returncode != 0:
        raise RuntimeError(f"UDP check failed with exit code {result.returncode}")


class Remote:
    label: str

    def pull_file(self, remote_path: str, local_path: Path) -> None:
        raise NotImplementedError

    def install_file(self, local_path: Path, remote_path: str, backup_path: str) -> None:
        raise NotImplementedError

    def restart_service(self, service: str) -> str:
        raise NotImplementedError


class AdbRemote(Remote):
    def __init__(self, adb: str, serial: str | None):
        self.adb = adb
        self.serial = serial or self._select_single_device()
        self.base = [adb, "-s", self.serial]
        self.label = f"adb:{self.serial}"

    def _select_single_device(self) -> str:
        if shutil.which(self.adb) is None:
            raise RuntimeError(f"adb executable not found: {self.adb}")
        run([self.adb, "start-server"])
        devices_output = run([self.adb, "devices"]).stdout
        devices = [
            parts[0]
            for line in devices_output.splitlines()[1:]
            if (parts := line.split()) and len(parts) >= 2 and parts[1] == "device"
        ]
        if not devices:
            raise RuntimeError("no adb device found. Connected devices:\n" + devices_output)
        if len(devices) > 1:
            raise RuntimeError("multiple adb devices found; rerun with --serial.\n" + devices_output)
        return devices[0]

    def shell(self, command: str, check: bool = True) -> subprocess.CompletedProcess[str]:
        return run(self.base + ["shell", command], check=check)

    def pull_file(self, remote_path: str, local_path: Path) -> None:
        run(self.base + ["pull", remote_path, str(local_path)])

    def install_file(self, local_path: Path, remote_path: str, backup_path: str) -> None:
        tmp_remote = f"/tmp/{Path(remote_path).name}.{os.getpid()}.new"
        run(self.base + ["push", str(local_path), tmp_remote])
        command = (
            f"cp -p {shell_quote(remote_path)} {shell_quote(backup_path)} && "
            f"cat {shell_quote(tmp_remote)} > {shell_quote(remote_path)} && "
            f"rm -f {shell_quote(tmp_remote)}"
        )
        self.shell(command)

    def restart_service(self, service: str) -> str:
        result = self.shell(f"systemctl restart {shell_quote(service)} && systemctl is-active {shell_quote(service)}")
        return result.stdout.strip()


class SshRemote(Remote):
    def __init__(self, args: Args):
        if not args.drone_ip:
            raise RuntimeError("SSH mode requires --drone-ip")
        self.target = f"{args.user}@{args.drone_ip}"
        self.port = str(args.ssh_port)
        self.env = None
        self.prefix: list[str] = []
        if args.password:
            sshpass = shutil.which("sshpass")
            if not sshpass:
                raise RuntimeError("SSH password mode requires sshpass; install it or use SSH keys with --password ''")
            self.env = os.environ.copy()
            self.env["SSHPASS"] = args.password
            self.prefix = [sshpass, "-e"]
        self.label = f"ssh:{self.target}"

    def ssh_cmd(self, command: str) -> list[str]:
        return self.prefix + ["ssh", "-p", self.port, "-o", "StrictHostKeyChecking=accept-new", self.target, command]

    def scp_cmd(self, source: str, dest: str) -> list[str]:
        return self.prefix + ["scp", "-P", self.port, "-o", "StrictHostKeyChecking=accept-new", source, dest]

    def pull_file(self, remote_path: str, local_path: Path) -> None:
        run(self.scp_cmd(f"{self.target}:{remote_path}", str(local_path)), env=self.env)

    def install_file(self, local_path: Path, remote_path: str, backup_path: str) -> None:
        tmp_remote = f"/tmp/{Path(remote_path).name}.{os.getpid()}.new"
        run(self.scp_cmd(str(local_path), f"{self.target}:{tmp_remote}"), env=self.env)
        command = (
            f"cp -p {shell_quote(remote_path)} {shell_quote(backup_path)} && "
            f"cat {shell_quote(tmp_remote)} > {shell_quote(remote_path)} && "
            f"rm -f {shell_quote(tmp_remote)}"
        )
        run(self.ssh_cmd(command), env=self.env)

    def restart_service(self, service: str) -> str:
        result = run(self.ssh_cmd(f"systemctl restart {shell_quote(service)} && systemctl is-active {shell_quote(service)}"), env=self.env)
        return result.stdout.strip()


def parse_args(argv: list[str]) -> Args:
    parser = argparse.ArgumentParser(description="Set a Starling/VOXL MAVLink static GCS IP over adb or SSH.")
    parser.add_argument("--ip", type=validate_ipv4, help="host computer IP to write; default is auto-detected")
    parser.add_argument("-i", "--interface", help="local interface to read IP from, e.g. en0 or wlan0")
    parser.add_argument("--transport", choices=("adb", "ssh"), help="default: adb, or ssh when --drone-ip is provided")
    parser.add_argument("--drone-ip", "--host", dest="drone_ip", help="drone IP for SSH mode")
    parser.add_argument("--user", default=DEFAULT_REMOTE_USER, help=f"SSH username; default: {DEFAULT_REMOTE_USER}")
    parser.add_argument("--password", default=DEFAULT_REMOTE_PASSWORD, help="SSH password for sshpass; use --password '' for SSH keys")
    parser.add_argument("--ssh-port", type=int, default=22, help="SSH port; default: 22")
    parser.add_argument("-s", "--serial", help="adb serial when more than one device is connected")
    parser.add_argument("--field", default=DEFAULT_FIELD, help=f"config field to update; default: {DEFAULT_FIELD}")
    parser.add_argument("--primary", action="store_const", dest="field", const="primary_static_gcs_ip")
    parser.add_argument("--config", default=DEFAULT_CONFIG_PATH, help=f"remote config path; default: {DEFAULT_CONFIG_PATH}")
    parser.add_argument("--service", default=DEFAULT_SERVICE, help=f"systemd service to restart; default: {DEFAULT_SERVICE}")
    parser.add_argument("--adb", default="adb", help="adb executable path; default: adb")
    parser.add_argument("--dry-run", action="store_true", help="show what would change without editing or restarting")
    parser.add_argument("--no-restart", action="store_true", help="update config but do not restart the service")
    parser.add_argument("--check-udp", action="store_true", help="after update/restart, listen for inbound MAVLink UDP")
    parser.add_argument("--udp-port", type=int, default=14550, help="UDP port for --check-udp; default: 14550")
    parser.add_argument("--udp-timeout", type=float, default=8.0, help="seconds to wait for --check-udp; default: 8")
    ns = parser.parse_args(argv)
    return Args(
        transport=ns.transport or ("ssh" if ns.drone_ip else "adb"),
        ip=ns.ip,
        interface=ns.interface,
        drone_ip=ns.drone_ip,
        user=ns.user,
        password=ns.password,
        ssh_port=ns.ssh_port,
        serial=ns.serial,
        field=ns.field,
        config=ns.config,
        service=ns.service,
        adb=ns.adb,
        dry_run=ns.dry_run,
        no_restart=ns.no_restart,
        check_udp=ns.check_udp,
        udp_port=ns.udp_port,
        udp_timeout=ns.udp_timeout,
    )


def main(argv: list[str] | None = None) -> int:
    args = parse_args(sys.argv[1:] if argv is None else argv)
    try:
        if args.transport == "ssh" and not args.drone_ip:
            raise RuntimeError("SSH mode requires --drone-ip")
        default_target = args.drone_ip if args.transport == "ssh" and args.drone_ip else "8.8.8.8"
        ip = args.ip or (detect_ip_for_interface(args.interface) if args.interface else detect_route_ip(default_target))
        remote: Remote = SshRemote(args) if args.transport == "ssh" else AdbRemote(args.adb, args.serial)

        with tempfile.TemporaryDirectory() as tmpdir:
            local_config = Path(tmpdir) / Path(args.config).name
            edited_config = Path(tmpdir) / f"{Path(args.config).name}.new"
            remote.pull_file(args.config, local_config)
            text = local_config.read_text(encoding="utf-8")
            new_text, old_ip = edit_config_text(text, args.field, ip)
            edited_config.write_text(new_text, encoding="utf-8")

            print(f"target: {remote.label}")
            print(f"host IP: {ip}")
            print(f"{args.field}: {old_ip or '<empty>'} -> {ip}")

            if args.dry_run:
                print("dry run: remote config was not changed and service was not restarted")
                return 0

            stamp = dt.datetime.utcnow().strftime("%Y%m%dT%H%M%SZ")
            backup_path = f"{args.config}.bak.{stamp}"
            remote.install_file(edited_config, args.config, backup_path)
            print(f"backup: {backup_path}")
            print(f"updated: {args.config}")

            if args.no_restart:
                print(f"restart skipped: run `systemctl restart {args.service}` on the drone when ready")
            else:
                status = remote.restart_service(args.service)
                print(f"{args.service}: {status or 'unknown'}")

            if args.check_udp:
                run_udp_checker(args.udp_port, args.udp_timeout)
    except RuntimeError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
