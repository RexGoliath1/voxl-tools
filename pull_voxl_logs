# ///
"""Pull VOXL/Starling ROS, terminal, and PX4 logs over adb or SSH/SCP."""

from __future__ import annotations

import argparse
import os
import re
import shutil
import subprocess
import sys
import tarfile
import tempfile
import time
from dataclasses import dataclass, field
from pathlib import Path


DEFAULT_STARLING_LOG_DIRS = [
    "/home/root/brecourt_tflite_tracker/brecourt/log/ros",
    "/data/brecourt_tflite_tracker/brecourt/log/ros",
    "/data/brecourt/brecourt/log/ros",
]
DEFAULT_HOST_LOG_DIRS = [
    "$HOME/git/Brecourt/brecourt_tflite_tracker/brecourt/log/ros",
    "$HOME/git/brecourt_tflite_tracker/brecourt/log/ros",
    "$HOME/brecourt_tflite_tracker/brecourt/log/ros",
]
DEFAULT_CONTAINER_LOG_DIRS = [
    "/root/brecourt/log/ros",
    "/root/.ros/log",
]
DEFAULT_PX4_LOG_DIRS = [
    "/data/px4/log",
]
STARLING_DISCOVERY_ROOTS = ["/data", "/home/root"]
HOST_DISCOVERY_ROOTS = ["$HOME"]


@dataclass
class Args:
    output_dir: Path
    source: str
    container: str | None
    adb: str
    serial: str | None
    scp: str | None
    no_discover: bool
    starling_log_dirs: list[str] = field(default_factory=list)
    host_log_dirs: list[str] = field(default_factory=list)
    container_log_dirs: list[str] = field(default_factory=list)
    px4_log_dirs: list[str] = field(default_factory=list)


def run(
    cmd: list[str],
    *,
    input_text: str | None = None,
    check: bool = True,
) -> subprocess.CompletedProcess[str]:
    try:
        result = subprocess.run(
            cmd,
            input=input_text,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
    except FileNotFoundError as exc:
        raise RuntimeError(f"{cmd[0]!r} was not found") from exc
    if check and result.returncode != 0:
        detail = result.stderr.strip() or result.stdout.strip() or f"exit code {result.returncode}"
        raise RuntimeError(f"{' '.join(cmd)} failed: {detail}")
    return result


def run_bytes(cmd: list[str], *, check: bool = True) -> subprocess.CompletedProcess[bytes]:
    try:
        result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    except FileNotFoundError as exc:
        raise RuntimeError(f"{cmd[0]!r} was not found") from exc
    if check and result.returncode != 0:
        detail = result.stderr.decode(errors="replace").strip() or result.stdout.decode(errors="replace").strip()
        raise RuntimeError(f"{' '.join(cmd)} failed: {detail or f'exit code {result.returncode}'}")
    return result


def shell_quote(value: str) -> str:
    return "'" + value.replace("'", "'\"'\"'") + "'"


def label(value: str) -> str:
    return re.sub(r"[^A-Za-z0-9_.-]", "_", value)


def parse_args(argv: list[str]) -> Args:
    parser = argparse.ArgumentParser(
        description="Pull VOXL/Starling ROS, terminal, and PX4 logs. Defaults to adb; use --scp for SSH/SCP.",
    )
    parser.add_argument("--serial", help="adb serial. Optional when exactly one adb device is attached.")
    parser.add_argument(
        "--scp",
        metavar="HOST",
        help="Use SSH/SCP instead of adb. Plain host/IP defaults to root@HOST.",
    )
    parser.add_argument("--adb", default="adb", help="adb executable. Default: adb")
    parser.add_argument("-o", "--output-dir", default="./logs", type=Path)
    parser.add_argument("-s", "--source", choices=("auto", "starling", "host", "docker"), default="auto")
    parser.add_argument("-c", "--container", help="Docker container id/name. Default: newest brecourt-ros2 container.")
    parser.add_argument("--starling-log-dir", action="append", default=[], help="Starling-side saved ROS log dir. Repeatable.")
    parser.add_argument("--host-log-dir", action="append", default=[], help="Host-user saved ROS log dir. Repeatable.")
    parser.add_argument(
        "--remote-repo-dir",
        action="append",
        default=[],
        help="Add DIR/brecourt/log/ros as a host log candidate. Repeatable.",
    )
    parser.add_argument(
        "--container-log-dir",
        "--docker-log-dir",
        dest="container_log_dir",
        action="append",
        default=[],
        help="Docker container ROS log dir. Repeatable.",
    )
    parser.add_argument("--no-discover", action="store_true", help="Do not search common remote roots for */brecourt/log/ros.")
    parser.add_argument("--px4-log-dir", action="append", default=[], help="PX4 ULog root directory. Repeatable. Default: /data/px4/log")
    parser.add_argument("--no-px4-logs", action="store_true", help="Do not pull PX4 ULog files.")
    ns = parser.parse_args(argv)

    starling_dirs = list(ns.starling_log_dir) or list(DEFAULT_STARLING_LOG_DIRS)
    host_dirs = list(ns.host_log_dir)
    host_dirs.extend(f"{repo.rstrip('/')}/brecourt/log/ros" for repo in ns.remote_repo_dir)
    if not host_dirs:
        host_dirs = list(DEFAULT_HOST_LOG_DIRS)

    return Args(
        output_dir=ns.output_dir,
        source=ns.source,
        container=ns.container,
        adb=ns.adb,
        serial=ns.serial,
        scp=ns.scp,
        no_discover=ns.no_discover,
        starling_log_dirs=starling_dirs,
        host_log_dirs=host_dirs,
        container_log_dirs=ns.container_log_dir or list(DEFAULT_CONTAINER_LOG_DIRS),
        px4_log_dirs=[] if ns.no_px4_logs else (ns.px4_log_dir or list(DEFAULT_PX4_LOG_DIRS)),
    )


class Remote:
    _home_dir: str | None = None

    def shell(self, command: str, check: bool = True) -> subprocess.CompletedProcess[str]:
        raise NotImplementedError

    def home_dir(self) -> str:
        if self._home_dir is None:
            result = self.shell('printf "%s" "$HOME"', check=False)
            self._home_dir = (result.stdout.strip() if result.returncode == 0 else "") or "/tmp"
        return self._home_dir

    def expand_path(self, path: str) -> str:
        home = self.home_dir().rstrip("/")
        if path == "$HOME" or path == "${HOME}" or path == "~":
            return home
        if path.startswith("$HOME/"):
            return home + path[len("$HOME") :]
        if path.startswith("${HOME}/"):
            return home + path[len("${HOME}") :]
        if path.startswith("~/"):
            return home + path[1:]
        return path

    def exists_nonempty_dir(self, path: str) -> bool:
        raise NotImplementedError

    def list_dirs(self, roots: list[str], path_suffix: str) -> list[str]:
        raise NotImplementedError

    def docker_ps(self, all_containers: bool) -> list[tuple[str, str, str]]:
        raise NotImplementedError

    def docker_env(self, container: str) -> dict[str, str]:
        raise NotImplementedError

    def copy_dir_to_local(self, remote_dir: str, local_dir: Path) -> None:
        raise NotImplementedError

    def dir_size_bytes(self, remote_dir: str) -> int | None:
        return self.dir_size_bytes_for_paths(remote_dir, None)

    def dir_size_bytes_for_paths(self, remote_dir: str, relative_paths: list[str] | None) -> int | None:
        if relative_paths is None:
            result = self.shell(f"du -sk {shell_quote(remote_dir)} 2>/dev/null | awk '{{print $1}}'", check=False)
        elif not relative_paths:
            return 0
        else:
            quoted_paths = " ".join(shell_quote(path) for path in relative_paths)
            result = self.shell(
                f"cd {shell_quote(remote_dir)} && du -sk {quoted_paths} 2>/dev/null | awk '{{s += $1}} END {{print s}}'",
                check=False,
            )
        if result.returncode != 0:
            return None
        text = result.stdout.strip().splitlines()
        if not text or not text[-1].strip().isdigit():
            return None
        return int(text[-1].strip()) * 1024

    def copy_container_dir_to_local(self, container: str, remote_dir: str, local_dir: Path) -> bool:
        raise NotImplementedError

    def read_first_existing_file(self, paths: list[str]) -> str | None:
        for path in paths:
            result = self.shell(f"cat {shell_quote(path)} 2>/dev/null", check=False)
            if result.returncode == 0 and result.stdout.strip():
                return result.stdout.strip().splitlines()[0].strip()
        return None


class AdbRemote(Remote):
    def __init__(self, adb: str, serial: str | None):
        self.adb = adb
        self.serial = serial or self._select_single_device()
        self.base = [adb, "-s", self.serial]

    def _select_single_device(self) -> str:
        if shutil.which(self.adb) is None:
            raise RuntimeError(f"adb executable not found: {self.adb}")
        run([self.adb, "start-server"])
        devices_output = run([self.adb, "devices"]).stdout
        devices = [
            parts[0]
            for line in devices_output.splitlines()[1:]
            if (parts := line.split()) and len(parts) >= 2 and parts[1] == "device"
        ]
        if not devices:
            raise RuntimeError("No ready adb device found.\n" + devices_output + "\nUse --scp <host> for SSH/SCP mode.")
        if len(devices) > 1:
            raise RuntimeError("Multiple adb devices are attached; rerun with --serial <serial>.\n" + devices_output)
        return devices[0]

    def shell(self, command: str, check: bool = True) -> subprocess.CompletedProcess[str]:
        marker = "__VOXL_TOOLS_RC__:"
        wrapped = f"sh -c {shell_quote(command)}; rc=$?; printf '\\n{marker}%s\\n' \"$rc\""
        result = run(self.base + ["shell", wrapped], check=False)
        stdout = result.stdout.replace("\r\n", "\n")
        match = re.search(rf"\n{re.escape(marker)}(\d+)\n?$", stdout)
        if match:
            result.returncode = int(match.group(1))
            result.stdout = stdout[: match.start()]
        if check and result.returncode != 0:
            detail = result.stderr.strip() or result.stdout.strip() or f"exit code {result.returncode}"
            raise RuntimeError(f"adb shell command failed: {detail}")
        return result

    def exists_nonempty_dir(self, path: str) -> bool:
        cmd = f"test -d {shell_quote(path)} && find {shell_quote(path)} -mindepth 1 -print -quit | grep -q ."
        return self.shell(cmd, check=False).returncode == 0

    def list_dirs(self, roots: list[str], path_suffix: str) -> list[str]:
        quoted_roots = " ".join(shell_quote(root) for root in roots)
        cmd = f"find {quoted_roots} -type d -path {shell_quote(path_suffix)} -print 2>/dev/null | sort -r"
        result = self.shell(cmd, check=False)
        return [line.strip("\r") for line in result.stdout.splitlines() if line.strip()]

    def docker_ps(self, all_containers: bool) -> list[tuple[str, str, str]]:
        all_flag = " -a" if all_containers else ""
        result = self.shell(f"docker ps{all_flag} --format '{{{{.ID}}}} {{{{.Image}}}} {{{{.Names}}}}'", check=False)
        return parse_docker_ps(result.stdout)

    def docker_env(self, container: str) -> dict[str, str]:
        cmd = f"docker inspect --format '{{{{range .Config.Env}}}}{{{{println .}}}}{{{{end}}}}' {shell_quote(container)}"
        result = self.shell(cmd, check=False)
        return parse_env(result.stdout)

    def copy_dir_to_local(self, remote_dir: str, local_dir: Path) -> None:
        local_dir.mkdir(parents=True, exist_ok=True)
        relative_paths = remote_paths_missing_locally(self, remote_dir, local_dir)
        if relative_paths is not None and not relative_paths:
            print(f"copy {remote_dir}: already up to date", file=sys.stderr)
            return
        tar_cmd = tar_command(remote_dir, relative_paths)
        stream_tar_to_local(
            self.base + ["exec-out", tar_cmd],
            local_dir,
            f"copy {remote_dir}",
            self.dir_size_bytes_for_paths(remote_dir, relative_paths),
        )

    def copy_container_dir_to_local(self, container: str, remote_dir: str, local_dir: Path) -> bool:
        tmp = f"/tmp/voxl_ros_logs_copy_{os.getpid()}"
        script = (
            f"rm -rf {shell_quote(tmp)} && mkdir -p {shell_quote(tmp)} && "
            f"docker cp {shell_quote(container + ':' + remote_dir + '/.')} {shell_quote(tmp)} >/dev/null 2>&1 && "
            f"find {shell_quote(tmp)} -mindepth 1 -print -quit | grep -q . && "
            f"tar -C {shell_quote(tmp)} -czf - .; "
            f"status=$?; rm -rf {shell_quote(tmp)}; exit $status"
        )
        result = run_bytes(self.base + ["exec-out", script], check=False)
        if result.returncode != 0:
            return False
        local_dir.mkdir(parents=True, exist_ok=True)
        extract_tar_bytes(result.stdout, local_dir)
        return True


class SshRemote(Remote):
    def __init__(self, target: str):
        self.target = target if "@" in target else f"root@{target}"

    def shell(self, command: str, check: bool = True) -> subprocess.CompletedProcess[str]:
        return self.ssh(command, check=check)

    def ssh(self, command: str, check: bool = True) -> subprocess.CompletedProcess[str]:
        return run(["ssh", self.target, command], check=check)

    def exists_nonempty_dir(self, path: str) -> bool:
        cmd = f"test -d {shell_quote(path)} && find {shell_quote(path)} -mindepth 1 -print -quit | grep -q ."
        return self.ssh(cmd, check=False).returncode == 0

    def list_dirs(self, roots: list[str], path_suffix: str) -> list[str]:
        quoted_roots = " ".join(shell_quote(root) for root in roots)
        cmd = f"find {quoted_roots} -type d -path {shell_quote(path_suffix)} -print 2>/dev/null | sort -r"
        result = self.ssh(cmd, check=False)
        return [line.strip() for line in result.stdout.splitlines() if line.strip()]

    def docker_ps(self, all_containers: bool) -> list[tuple[str, str, str]]:
        all_flag = " -a" if all_containers else ""
        result = self.ssh(f"docker ps{all_flag} --format '{{{{.ID}}}} {{{{.Image}}}} {{{{.Names}}}}'", check=False)
        return parse_docker_ps(result.stdout)

    def docker_env(self, container: str) -> dict[str, str]:
        cmd = f"docker inspect --format '{{{{range .Config.Env}}}}{{{{println .}}}}{{{{end}}}}' {shell_quote(container)}"
        result = self.ssh(cmd, check=False)
        return parse_env(result.stdout)

    def copy_dir_to_local(self, remote_dir: str, local_dir: Path) -> None:
        local_dir.mkdir(parents=True, exist_ok=True)
        relative_paths = remote_paths_missing_locally(self, remote_dir, local_dir)
        if relative_paths is not None and not relative_paths:
            print(f"copy {remote_dir}: already up to date", file=sys.stderr)
            return
        tar_cmd = tar_command(remote_dir, relative_paths)
        stream_tar_to_local(
            ["ssh", self.target, tar_cmd],
            local_dir,
            f"copy {remote_dir}",
            self.dir_size_bytes_for_paths(remote_dir, relative_paths),
        )

    def copy_container_dir_to_local(self, container: str, remote_dir: str, local_dir: Path) -> bool:
        tmp = f"/tmp/voxl_ros_logs_copy_{os.getpid()}"
        script = (
            f"rm -rf {shell_quote(tmp)} && mkdir -p {shell_quote(tmp)} && "
            f"docker cp {shell_quote(container + ':' + remote_dir + '/.')} {shell_quote(tmp)} >/dev/null 2>&1 && "
            f"find {shell_quote(tmp)} -mindepth 1 -print -quit | grep -q . && "
            f"tar -C {shell_quote(tmp)} -czf - .; "
            f"status=$?; rm -rf {shell_quote(tmp)}; exit $status"
        )
        result = run_bytes(["ssh", self.target, script], check=False)
        if result.returncode != 0:
            return False
        local_dir.mkdir(parents=True, exist_ok=True)
        extract_tar_bytes(result.stdout, local_dir)
        return True


def parse_docker_ps(output: str) -> list[tuple[str, str, str]]:
    rows = []
    for line in output.splitlines():
        parts = line.split(maxsplit=2)
        if len(parts) >= 2:
            rows.append((parts[0], parts[1], parts[2] if len(parts) == 3 else ""))
    return rows


def parse_env(output: str) -> dict[str, str]:
    env = {}
    for line in output.splitlines():
        key, sep, value = line.partition("=")
        if sep:
            env[key] = value
    return env


def extract_tar_bytes(data: bytes, destination: Path) -> None:
    if not data.startswith(b"\x1f\x8b"):
        detail = data[:200].decode(errors="replace").strip()
        raise RuntimeError(f"remote tar stream was not gzip data: {detail}")
    with tempfile.NamedTemporaryFile(suffix=".tar.gz") as tmp:
        tmp.write(data)
        tmp.flush()
        with tarfile.open(tmp.name, "r:gz") as tar:
            tar.extractall(destination)
    normalize_permissions(destination)


def remote_paths_missing_locally(remote: Remote, remote_dir: str, local_dir: Path) -> list[str] | None:
    if not any(local_dir.rglob("*")):
        return None
    result = remote.shell(
        f"cd {shell_quote(remote_dir)} && find . -type f 2>/dev/null | "
        "while IFS= read -r path; do rel=${path#./}; size=$(wc -c < \"$path\" 2>/dev/null) || continue; "
        "printf '%s\\t%s\\n' \"$rel\" \"$size\"; done | sort",
        check=False,
    )
    if result.returncode != 0:
        return None
    missing = []
    for line in result.stdout.splitlines():
        rel, sep, size_text = line.partition("\t")
        if not sep or not rel or rel.startswith("/") or ".." in Path(rel).parts:
            continue
        local = local_dir / rel
        try:
            local_size = local.stat().st_size
        except FileNotFoundError:
            missing.append(rel)
            continue
        if not size_text.isdigit() or local_size != int(size_text):
            missing.append(rel)
    if len(missing) > 500 or sum(len(path) + 1 for path in missing) > 20000:
        return None
    return missing


def tar_command(remote_dir: str, relative_paths: list[str] | None) -> str:
    if relative_paths is None:
        return f"tar -C {shell_quote(remote_dir)} -cf - ."
    return f"cd {shell_quote(remote_dir)} && tar -cf - {' '.join(shell_quote(path) for path in relative_paths)}"


def stream_tar_to_local(cmd: list[str], destination: Path, label_text: str, total_bytes: int | None) -> None:
    destination.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile(suffix=".tar") as tmp:
        try:
            process = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        except FileNotFoundError as exc:
            raise RuntimeError(f"{cmd[0]!r} was not found") from exc
        assert process.stdout is not None
        received = 0
        last_render = 0.0
        while True:
            chunk = process.stdout.read(1024 * 1024)
            if not chunk:
                break
            tmp.write(chunk)
            received += len(chunk)
            now = time.monotonic()
            if now - last_render >= 0.2:
                render_progress(label_text, received, total_bytes, done=False)
                last_render = now
        stderr = process.stderr.read().decode(errors="replace") if process.stderr else ""
        rc = process.wait()
        render_progress(label_text, received, total_bytes, done=True)
        if rc != 0:
            raise RuntimeError(stderr.strip() or f"tar stream failed for {label_text}")
        tmp.flush()
        tmp.seek(0)
        with tarfile.open(tmp.name, "r:") as tar:
            tar.extractall(destination)
    normalize_permissions(destination)


def render_progress(label_text: str, received: int, total: int | None, done: bool) -> None:
    width = 24
    if total and total > 0:
        ratio = min(received / total, 1.0)
        filled = int(ratio * width)
        bar = "#" * filled + "-" * (width - filled)
        text = f"\r{label_text}: [{bar}] {format_bytes(received)} / {format_bytes(total)} {ratio * 100:5.1f}%"
    else:
        text = f"\r{label_text}: {format_bytes(received)}"
    end = "\n" if done else ""
    print(text, end=end, file=sys.stderr, flush=True)


def format_bytes(value: int) -> str:
    amount = float(value)
    for unit in ("B", "KB", "MB", "GB"):
        if amount < 1024.0 or unit == "GB":
            return f"{amount:.1f} {unit}"
        amount /= 1024.0


def detect_vehicle_id(remote: Remote) -> str:
    hostname = remote.shell("hostname 2>/dev/null", check=False).stdout.strip().splitlines()
    hostname = hostname[0].strip() if hostname else ""
    machine_id = remote.read_first_existing_file(["/etc/machine-id", "/var/lib/dbus/machine-id"])
    sku = remote.read_first_existing_file(["/data/modalai/sku.txt"])
    hardware = detect_hardware_platform(remote)
    mav_sys_id = read_px4_param(remote, "MAV_SYS_ID")

    parts = []
    if hostname:
        parts.append(hostname)
    if sku:
        parts.append(normalize_token(sku))
    elif hardware:
        parts.append(hardware)
    if mav_sys_id:
        parts.append(f"sys{mav_sys_id}")
    if machine_id:
        parts.append(machine_id[:12])
    if not parts:
        parts.append("unknown_voxl")
    return label("_".join(parts))


def normalize_token(value: str) -> str:
    return value.strip().split()[0]


def detect_hardware_platform(remote: Remote) -> str | None:
    result = remote.shell("voxl-platform 2>/dev/null", check=False)
    text = (result.stdout or result.stderr).strip()
    match = re.search(r"\bM\d{4}\b", text)
    return match.group(0) if match else None


def read_px4_param(remote: Remote, name: str) -> str | None:
    result = remote.shell(f"px4-param show {shell_quote(name)} 2>/dev/null", check=False)
    if result.returncode != 0:
        return None
    for line in result.stdout.splitlines():
        if name not in line:
            continue
        _, _, value = line.partition(":")
        value = value.strip()
        if value:
            return value.split()[0]
    return None


def normalize_permissions(path: Path) -> None:
    for child in path.rglob("*"):
        child.chmod(0o755 if child.is_dir() else 0o644)
    path.chmod(0o755)


def select_container(remote: Remote, requested: str | None) -> str | None:
    if requested:
        return requested
    for all_containers in (False, True):
        for cid, image, name in remote.docker_ps(all_containers):
            if "brecourt-ros2" in image or "brecourt-ros2" in name:
                return cid
    return None


def expand_paths(remote: Remote, paths: list[str]) -> list[str]:
    return list(dict.fromkeys(remote.expand_path(path) for path in paths))


def parent_dir(path: str) -> str:
    return path.rstrip("/").rsplit("/", 1)[0] or "/"


def log_bundle_dirs(path: str) -> list[tuple[str, str]]:
    clean = path.rstrip("/")
    name = clean.rsplit("/", 1)[-1]
    if name == "ros":
        root = parent_dir(clean)
        return [("ros", clean), ("terminal", f"{root}/terminal")]
    if name == "terminal":
        return [("terminal", clean)]
    if name == "log":
        return [("ros", f"{clean}/ros"), ("terminal", f"{clean}/terminal")]
    return [(name, clean)]


def pull_log_bundle(remote: Remote, name: str, path: str, dest: Path) -> bool:
    copied = False
    for local_name, remote_path in log_bundle_dirs(path):
        if remote.exists_nonempty_dir(remote_path):
            print(f"source={name}:{remote_path}", file=sys.stderr)
            remote.copy_dir_to_local(remote_path, dest / local_name)
            copied = True
    return copied


def pull_named_dirs(remote: Remote, name: str, dirs: list[str], roots: list[str], discover: bool, dest: Path) -> bool:
    for path in expand_paths(remote, dirs):
        if pull_log_bundle(remote, name, path, dest):
            return True
    if discover:
        for path in remote.list_dirs(expand_paths(remote, roots), "*/brecourt/log/ros"):
            if pull_log_bundle(remote, name, path, dest):
                return True
    return False


def pull_docker_logs(remote: Remote, args: Args, dest: Path) -> bool:
    container = select_container(remote, args.container)
    if not container:
        return False
    candidates = []
    ros_log_dir = remote.docker_env(container).get("ROS_LOG_DIR")
    if ros_log_dir:
        candidates.append(ros_log_dir)
    candidates.extend(args.container_log_dirs)
    for path in dict.fromkeys(candidates):
        if remote.copy_container_dir_to_local(container, path, dest):
            print(f"source=docker:{container}:{path}", file=sys.stderr)
            return True
    return False


def pull_px4_logs(remote: Remote, args: Args, dest: Path) -> bool:
    for path in expand_paths(remote, args.px4_log_dirs):
        if remote.exists_nonempty_dir(path):
            print(f"source=px4:{path}", file=sys.stderr)
            remote.copy_dir_to_local(path, dest / "px4")
            return True
    return False


def pull_logs(remote: Remote, args: Args, dest: Path) -> None:
    dest.mkdir(parents=True, exist_ok=True)
    copied_ros_logs = False
    ros_error = "no ROS logs found in Starling, host-user, or Docker paths"
    if args.source == "starling":
        copied_ros_logs = pull_named_dirs(remote, "starling", args.starling_log_dirs, STARLING_DISCOVERY_ROOTS, not args.no_discover, dest)
        ros_error = "no non-empty Starling ROS log directory found"
    elif args.source == "host":
        copied_ros_logs = pull_named_dirs(remote, "host", args.host_log_dirs, HOST_DISCOVERY_ROOTS, not args.no_discover, dest)
        ros_error = "no non-empty host-user ROS log directory found"
    elif args.source == "docker":
        copied_ros_logs = pull_docker_logs(remote, args, dest)
        ros_error = "no non-empty ROS log directory found in Docker"
    else:
        copied_ros_logs = (
            pull_named_dirs(remote, "starling", args.starling_log_dirs, STARLING_DISCOVERY_ROOTS, not args.no_discover, dest)
            or pull_named_dirs(remote, "host", args.host_log_dirs, HOST_DISCOVERY_ROOTS, not args.no_discover, dest)
            or pull_docker_logs(remote, args, dest)
        )
    copied_px4_logs = pull_px4_logs(remote, args, dest)
    if not copied_ros_logs and copied_px4_logs:
        print(f"warning: {ros_error}", file=sys.stderr)
    if args.px4_log_dirs and not copied_px4_logs:
        print("warning: no non-empty PX4 log directory found", file=sys.stderr)
    if not copied_ros_logs and not copied_px4_logs:
        raise RuntimeError(ros_error)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(sys.argv[1:] if argv is None else argv)
    try:
        if args.scp:
            remote = SshRemote(args.scp)
            target = label(remote.target)
        else:
            remote = AdbRemote(args.adb, args.serial)
        target = detect_vehicle_id(remote)
        dest = args.output_dir / target
        print(f"Output directory: {dest.resolve()}")
        pull_logs(remote, args, dest)
        print(f"Copied logs to: {dest.resolve()}")
    except RuntimeError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
