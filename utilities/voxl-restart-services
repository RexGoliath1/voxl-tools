}


def run(cmd, check=True, env=None):
    try:
        result = subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            universal_newlines=True,
            env=env,
        )
    except FileNotFoundError as exc:
        raise RuntimeError("{} was not found".format(cmd[0])) from exc
    if check and result.returncode != 0:
        detail = result.stderr.strip() or result.stdout.strip() or "exit code {}".format(result.returncode)
        raise RuntimeError("{} failed: {}".format(" ".join(cmd), detail))
    return result


def shell_quote(value):
    return "'" + value.replace("'", "'\"'\"'") + "'"


def parse_marked_result(result):
    text = result.stdout or ""
    marker_index = text.rfind(EXIT_MARKER)
    if marker_index < 0:
        return result.returncode, result.stdout, result.stderr
    rc_text = text[marker_index + len(EXIT_MARKER) :].strip().splitlines()[0]
    stdout = text[:marker_index].rstrip("\n")
    try:
        rc = int(rc_text)
    except ValueError:
        rc = result.returncode
    return rc, stdout, result.stderr


def marked_shell(command):
    script = command + "\nrc=$?\nprintf '\\n{}%s\\n' \"$rc\"\nexit \"$rc\"".format(EXIT_MARKER)
    return "sh -lc {}".format(shell_quote(script))


class Target:
    label = "unknown"

    def shell(self, command, check=True):
        raise NotImplementedError


class LocalTarget(Target):
    label = "local"

    def shell(self, command, check=True):
        return run(["sh", "-lc", command], check=check)


class AdbTarget(Target):
    def __init__(self, adb, serial):
        self.adb = adb
        self.serial = serial or self._select_single_device()
        self.label = "adb:{}".format(self.serial)

    def _select_single_device(self):
        if shutil.which(self.adb) is None:
            raise RuntimeError("adb executable not found: {}".format(self.adb))
        run([self.adb, "start-server"])
        devices_output = run([self.adb, "devices"]).stdout
        devices = []
        for line in devices_output.splitlines()[1:]:
            parts = line.split()
            if len(parts) >= 2 and parts[1] == "device":
                devices.append(parts[0])
        if not devices:
            raise RuntimeError("no adb device found. Connected devices:\n{}".format(devices_output))
        if len(devices) > 1:
            raise RuntimeError("multiple adb devices found; rerun with --serial.\n{}".format(devices_output))
        return devices[0]

    def shell(self, command, check=True):
        result = run([self.adb, "-s", self.serial, "shell", marked_shell(command)], check=False)
        rc, stdout, stderr = parse_marked_result(result)
        completed = subprocess.CompletedProcess(result.args, rc, stdout, stderr)
        if check and rc != 0:
            detail = stderr.strip() or stdout.strip() or "exit code {}".format(rc)
            raise RuntimeError("adb shell failed: {}".format(detail))
        return completed


class SshTarget(Target):
    def __init__(self, args):
        self.target = "{}@{}".format(args.user, args.host)
        self.port = str(args.ssh_port)
        self.env = None
        self.prefix = []
        if args.password:
            sshpass = shutil.which("sshpass")
            if not sshpass:
                raise RuntimeError("SSH password mode requires sshpass; install it or use SSH keys with --password ''")
            self.env = os.environ.copy()
            self.env["SSHPASS"] = args.password
            self.prefix = [sshpass, "-e"]
        self.label = "ssh:{}".format(self.target)

    def shell(self, command, check=True):
        ssh_cmd = self.prefix + [
            "ssh",
            "-p",
            self.port,
            "-o",
            "StrictHostKeyChecking=accept-new",
            self.target,
            marked_shell(command),
        ]
        result = run(ssh_cmd, check=False, env=self.env)
        rc, stdout, stderr = parse_marked_result(result)
        completed = subprocess.CompletedProcess(result.args, rc, stdout, stderr)
        if check and rc != 0:
            detail = stderr.strip() or stdout.strip() or "exit code {}".format(rc)
            raise RuntimeError("ssh command failed: {}".format(detail))
        return completed


def local_voxl_available():
    return os.path.exists("/data/modalai/sku.txt") or os.path.exists("/etc/modalai")


def adb_device_available(adb):
    if shutil.which(adb) is None:
        return False
    result = run([adb, "devices"], check=False)
    return any(line.split()[1:2] == ["device"] for line in result.stdout.splitlines()[1:])


def choose_target(args):
    if args.transport == "local":
        return LocalTarget()
    if args.transport == "adb":
        return AdbTarget(args.adb, args.serial)
    if args.transport == "ssh":
        if not args.host:
            raise RuntimeError("SSH transport requires --host")
        return SshTarget(args)
    if args.host:
        return SshTarget(args)
    if local_voxl_available():
        return LocalTarget()
    if adb_device_available(args.adb):
        return AdbTarget(args.adb, args.serial)
    raise RuntimeError(
        "could not find a VOXL target. Connect adb, pass --host for SSH, or run on the VOXL with --transport local."
    )


def unit_name(name):
    if name.endswith(".service"):
        name = name[:-8]
    return ALIASES.get(name, name)


def service_exists(target, service):
    result = target.shell("systemctl status {} 2>&1".format(shell_quote(service)), check=False)
    text = (result.stdout or "") + (result.stderr or "")
    return "Loaded: not-found" not in text and "could not be found" not in text


def is_enabled(target, service):
    result = target.shell("systemctl is-enabled {} 2>/dev/null".format(shell_quote(service)), check=False)
    return result.stdout.strip() or "unknown"


def is_active(target, service):
    result = target.shell("systemctl is-active {} 2>/dev/null".format(shell_quote(service)), check=False)
    return result.stdout.strip() or "unknown"


def discovered_services(target):
    result = target.shell("systemctl list-unit-files --type=service --no-legend", check=False)
    services = []
    for line in result.stdout.splitlines():
        parts = line.split()
        if not parts:
            continue
        unit = parts[0]
        if not unit.endswith(".service"):
            continue
        service = unit[:-8]
        if service.startswith("voxl-") or service.startswith("qrb5165-"):
            services.append(service)
    return sorted(set(services))


def ordered_menu_services(target):
    common = [service for _, service in COMMON_SERVICES]
    discovered = [service for service in discovered_services(target) if service not in common]
    return common + discovered


def print_services(target, services):
    print("target: {}".format(target.label))
    for index, service in enumerate(services, start=1):
        print(
            "{:2d}. {:32s} enabled={:10s} active={}".format(
                index,
                service,
                is_enabled(target, service),
                is_active(target, service),
            )
        )


def parse_selection(text, services):
    selected = []
    by_index = {str(index): service for index, service in enumerate(services, start=1)}
    for raw in text.replace(",", " ").split():
        service = by_index.get(raw) or unit_name(raw)
        if service not in selected:
            selected.append(service)
    return selected


def interactive_select(target):
    services = ordered_menu_services(target)
    print_services(target, services)
    print("")
    print("Select services by number or name, separated by spaces or commas.")
    answer = input("restart> ").strip()
    if not answer:
        return []
    return parse_selection(answer, services)


def restart_service(target, service, dry_run=False):
    command = "systemctl restart {}".format(shell_quote(service))
    if dry_run:
        print("[dry] {}: {}".format(target.label, command))
        return 0
    result = target.shell(command, check=False)
    if result.returncode != 0:
        detail = result.stderr.strip() or result.stdout.strip() or "exit code {}".format(result.returncode)
        print("ERR  {}: {}".format(service, detail), file=sys.stderr)
        return result.returncode
    print("ok   {}: active={}".format(service, is_active(target, service)))
    return 0


def parse_args(argv):
    parser = argparse.ArgumentParser(description="Restart VOXL systemd services over adb, SSH, or locally.")
    parser.add_argument(
        "--transport",
        choices=("auto", "adb", "ssh", "local"),
        default="auto",
        help="target transport; default: auto",
    )
    parser.add_argument("--adb", default="adb", help="adb executable path; default: adb")
    parser.add_argument("-s", "--serial", help="adb serial when more than one device is connected")
    parser.add_argument("--host", "--drone-ip", dest="host", help="VOXL IP/hostname for SSH mode")
    parser.add_argument("--user", default=DEFAULT_REMOTE_USER, help="SSH username; default: root")
    parser.add_argument(
        "--password",
        default=DEFAULT_REMOTE_PASSWORD,
        help="SSH password for sshpass; use --password '' for SSH keys",
    )
    parser.add_argument("--ssh-port", type=int, default=22, help="SSH port; default: 22")
    parser.add_argument(
        "services",
        nargs="*",
        help="services or aliases to restart, e.g. camera mavlink vision",
    )
    parser.add_argument("--list", action="store_true", help="show common and discovered VOXL services")
    parser.add_argument("--status", action="store_true", help="show status for selected services without restarting")
    parser.add_argument("--dry-run", action="store_true", help="print restart commands without running them")
    parser.add_argument("--yes", action="store_true", help="do not prompt before restarting selected services")
    return parser.parse_args(argv)


def main(argv=None):
    args = parse_args(sys.argv[1:] if argv is None else argv)
    try:
        if args.dry_run and args.services and args.transport == "auto" and not args.host:
            target = Target()
            target.label = "auto"
        else:
            target = choose_target(args)

        if args.list:
            print_services(target, ordered_menu_services(target))
            return 0

        selected = [unit_name(name) for name in args.services] if args.services else interactive_select(target)
        if not selected:
            print("no services selected")
            return 0

        if not args.dry_run:
            missing = [service for service in selected if not service_exists(target, service)]
            if missing:
                print("WARNING: not found by systemctl: {}".format(", ".join(missing)), file=sys.stderr)

        if args.status:
            print_services(target, selected)
            return 0

        print("target: {}".format(target.label))
        print("selected: {}".format(", ".join(selected)))
        if not args.yes and not args.dry_run:
            answer = input("Restart selected services now? [y/N] ").strip().lower()
            if answer not in ("y", "yes"):
                print("aborted")
                return 0

        failed = 0
        for service in selected:
            failed += 1 if restart_service(target, service, args.dry_run) else 0
        return 1 if failed else 0
    except RuntimeError as exc:
        print("ERROR: {}".format(exc), file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())
